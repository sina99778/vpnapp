# ── Server ──
PORT=3000

# ── Auth (access-JWT verification) ──
# Use EITHER JWT_SECRET (HS256) OR a JWT_PRIVATE_KEY/JWT_PUBLIC_KEY pair (RS256).
JWT_SECRET=__set_a_long_random_secret__
# JWT_PRIVATE_KEY=   # PEM, for signing (RS256)
# JWT_PUBLIC_KEY=    # PEM, for verifying (RS256)
JWT_ISSUER=securevpn
JWT_AUDIENCE=securevpn-clients
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_MS=2592000000        # 30 days
LOGIN_MAX_FAILED=5
LOGIN_LOCKOUT_MS=900000                # 15 min
# Argon2id cost (raise after an audit without a rebuild).
ARGON_MEMORY_MIB=64
ARGON_TIME_COST=3
ARGON_PARALLELISM=4

# ── Admin / Ops ──
ADMIN_GRANT_DAYS=30                    # length of an admin-granted promo premium
# Telegram Ops bot — leave TOKEN unset to disable the bot entirely.
# TELEGRAM_BOT_TOKEN=123456:ABC...
ADMIN_TELEGRAM_IDS=                    # comma-separated numeric Telegram IDs (absolute whitelist)

# ── Database ──
DATABASE_URL=postgres://vpn:vpn@localhost:5432/vpn
PG_POOL_MAX=20

# ── Panel selection ──
# Which panel backs the service: "rebecca" (Marzban-family) or "remnawave".
PANEL_PROVIDER=rebecca
PANEL_TIMEOUT_MS=8000

# ── Rebecca panel (used when PANEL_PROVIDER=rebecca; private network only) ──
PANEL_BASE_URL=https://panel.internal:8000
PANEL_ADMIN_USER=__set_me__
PANEL_ADMIN_PASS=__set_me__

# ── Remnawave panel (used when PANEL_PROVIDER=remnawave; https://docs.rw) ──
# REMNAWAVE_BASE_URL=https://panel.example.com   # origin; the client appends /api
# REMNAWAVE_TOKEN=__panel_api_token__            # sent as Authorization: Bearer
# REMNAWAVE_CADDY_TOKEN=                         # optional X-Api-Key for caddy-with-auth
# Internal-squad UUID(s) that scope which nodes/inbounds a created user can use
# (Remnawave's equivalent of an inbound allow-list). Comma-separated, REQUIRED
# when PANEL_PROVIDER=remnawave — empty means no access scope (fail-closed).
# REMNAWAVE_SQUAD_UUIDS=

# ── Connection / tiers ──
FREE_MAX_SESSIONS=1
PREMIUM_MAX_SESSIONS=3
FREE_PROVISIONING_TTL_MS=300000      # 5 min
PREMIUM_FALLBACK_TTL_MS=2592000000   # 30 days (only for null-ended/promo plans)
CONNECT_REQUIRED_ADS=2
CONNECT_GRANT_MINUTES=60
VLESS_FLOW=xtls-rprx-vision

# ── Ads / reward ──
AD_TOKEN_WINDOW_MIN=15
MAX_SESSION_MINUTES=1440

# ── Workers ──
OUTBOX_BATCH=20
OUTBOX_TICK_MS=5000
OUTBOX_LEASE_MIN=2
OUTBOX_MAX_ATTEMPTS=12
REAPER_BATCH=500

# ── Attestation: Android / Play Integrity ──
ANDROID_PACKAGE_NAME=app.securevpn
GOOGLE_APPLICATION_CREDENTIALS=/secrets/play-integrity-sa.json
ANDROID_CERT_SHA256_B64=               # comma-separated signing-cert digests; empty = skip
ANDROID_TOKEN_MAX_AGE_MS=300000

# ── Attestation: iOS / App Attest ──
APPLE_TEAM_ID=__TEAMID__
APPLE_BUNDLE_ID=app.securevpn
APPLE_ATTEST_ENV=production            # production | development
# Path or inline PEM of Apple's App Attest Root CA (apple.com/certificateauthority).
APPLE_APPATTEST_ROOT_CA_PEM=/secrets/Apple_App_Attestation_Root_CA.pem

# ── Attestation: common ──
ATTEST_CHALLENGE_TTL_MS=300000         # 5 min
ATTEST_TTL_MS=86400000                 # 24h — device must re-attest after this
