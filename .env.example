# Compose-level configuration (interpolated into docker-compose.yml).
# install.sh generates a real .env from this automatically.

POSTGRES_USER=vpn
POSTGRES_PASSWORD=__generate_a_strong_password__
POSTGRES_DB=vpn

# URL the ADMIN'S BROWSER uses to reach the API. Baked into the dashboard
# image at BUILD time — after changing it run: docker compose up -d --build web
NEXT_PUBLIC_API_URL=http://localhost:3000/api/v1

# Number of reverse-proxy hops in front of the api (affects client IPs in
# rate-limiting and audit logs). 1 = a single nginx/caddy in front.
TRUST_PROXY_HOPS=1
